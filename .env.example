# Copy to .env.local for local dev: cp .env.example .env.local
# On Netlify, set these under Site configuration -> Environment variables.
# NEXT_PUBLIC_* values are inlined into the client bundle at build time — never
# put a secret behind a NEXT_PUBLIC_ name.

# --- Supabase (Project Settings -> API) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Bypasses Row Level Security — used for order verification.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Reown / WalletConnect (dashboard.reown.com) ---
NEXT_PUBLIC_REOWN_PROJECT_ID=your-reown-project-id

# --- App ---
# Base URL for public creator links. Must be the real origin in production
# (e.g. https://your-site.netlify.app) — it is baked in at build time.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# "testnet" (Sepolia + Tron Nile) or "mainnet"
NEXT_PUBLIC_CRYPTO_ENV=testnet

# --- Admin analytics (/v1/admin) ---
# HTTP Basic Auth for the app-wide analytics dashboard. Server-only — no
# NEXT_PUBLIC_ prefix, so these never reach the client bundle. If unset, the app
# falls back to the built-in defaults (john / Qspl@1234); override them in any
# real deployment.
ADMIN_USER=john
ADMIN_PASSWORD=Qspl@1234

# --- EVM RPCs (optional; public defaults exist, but they rate-limit) ---
RPC_ETHEREUM=
RPC_POLYGON=
RPC_ARBITRUM=
RPC_BASE=

# --- Tron (TronGrid) ---
TRON_FULL_HOST=https://api.trongrid.io
TRON_FULL_HOST_TESTNET=https://nile.trongrid.io
TRON_API_KEY=your-trongrid-api-key
